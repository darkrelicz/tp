@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant "c:DeletePersonCommand" as DeletePersonCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
participant ":AddressBook" as AddressBook MODEL_COLOR
end box

box Storage STORAGE_COLOR_T1
participant ":Storage" as Storage STORAGE_COLOR
end box

[-> LogicManager : execute("delete student 1")
activate LogicManager

LogicManager -> DeletePersonCommand : execute(m)
activate DeletePersonCommand

DeletePersonCommand -> Model : getFilteredPersonList()
activate Model
Model --> DeletePersonCommand : displayed students
deactivate Model

DeletePersonCommand -> Model : deletePerson(personToDelete)
activate Model
Model -> AddressBook : removePerson(personToDelete)
activate AddressBook
AddressBook --> Model
deactivate AddressBook
Model --> DeletePersonCommand
deactivate Model

create CommandResult
DeletePersonCommand -> CommandResult : CommandResult(...)
activate CommandResult
CommandResult --> DeletePersonCommand : r
deactivate CommandResult

DeletePersonCommand --> LogicManager : r
deactivate DeletePersonCommand

LogicManager -> Model : getAddressBook()
activate Model
Model --> LogicManager : updated address book
deactivate Model

LogicManager -> Storage : saveAddressBook(...)
activate Storage
Storage --> LogicManager
deactivate Storage

[<-- LogicManager
deactivate LogicManager
@enduml
