@startuml
!include style.puml
!pragma layout smetana
skinparam arrowThickness 1.1
skinparam arrowColor LOGIC_COLOR_T4
skinparam classBackgroundColor LOGIC_COLOR
top to bottom direction

package "Delete command hierarchy" {
abstract class "{abstract}\nCommand" as Command
abstract class "{abstract}\nIndexedPersonCommand" as IndexedPersonCommand
abstract class "{abstract}\nDeleteCommand" as DeleteCommand

class DeletePersonCommand
class DeletePaymentCommand
}

IndexedPersonCommand -up-|> Command
DeleteCommand -up-|> IndexedPersonCommand

DeletePersonCommand -up-|> DeleteCommand
DeletePaymentCommand -up-|> DeleteCommand

note right of DeleteCommand
All delete subcommands share the same
top-level command word: `delete`.
end note

note right of DeletePaymentCommand
Concrete delete subcommands encapsulate
subcommand-specific deletion behavior.
end note

@enduml
